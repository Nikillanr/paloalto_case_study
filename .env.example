# Groq API key (free — sign up at console.groq.com)
GROQ_API_KEY=your-groq-key-here

# Groq model to use (8B instant has 500K daily tokens on free tier)
GROQ_MODEL=llama-3.1-8b-instant

# Toggle AI analysis (set to false to force fallback mode)
AI_ENABLED=true

# SQLite database path
DATABASE_PATH=data/guardian.db
